# Copy to .env and fill in your GitHub Personal Access Token (repo scope).
# Used by scripts/update_repo.sh for git pull/push over HTTPS.
# .env is ignored by git — do not commit real tokens.

GITHUB_TOKEN=

# Optional: git pull/push retry (defaults: 5 attempts, delay i*3 seconds)
# GIT_RETRY_MAX=5
# GIT_RETRY_DELAY=3
